{
  // For more information, visit: https://angular.dev/ai/mcp
  "servers": {
    "angular-cli": {
      "command": "/bin/bash",
      "args": ["-lc", "if [ -z \"$NVM_DIR\" ]; then export NVM_DIR=\"$HOME/.nvm\"; fi && if [ -s \"$NVM_DIR/nvm.sh\" ]; then . \"$NVM_DIR/nvm.sh\"; if [ -f .nvmrc ]; then nvm use --silent >/dev/null; fi; fi && exec npx -y @angular/cli mcp"]
    }
  }
}
